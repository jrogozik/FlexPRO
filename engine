    // --- LOGARYTMIKA ---
    function logToVal(val, v_min, v_max) {
        v_min = Math.max(1, v_min);
        return v_min * Math.pow((v_max / v_min), (parseFloat(val) / 1000));
    }

    function valToLog(val, v_min, v_max) {
        v_min = Math.max(1, v_min);
        val = Math.max(v_min, val);
        return (Math.log(val / v_min) / Math.log(v_max / v_min)) * 1000;
    }

