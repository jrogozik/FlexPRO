    function customConfirm(message, title, callback, okLabel, cancelLabel, mode, values) {
        const t = translations[currentLang];
        const overlay = document.createElement("div");
        overlay.className = "custom-modal-overlay";
        const vals = values || { currentR: 0, newR: 0, currentA: 0, newA: 0 };

        overlay.innerHTML = `
            <div class="custom-modal">
                <div class="modal-title">${title}</div>
                <hr class="separator">
                <div class="modal-text" style="margin-bottom: 20px;">${message}</div>
                <div class="modal-btns" style="display: flex; gap: 15px; justify-content: center;">
                    
                    <button class="modal-btn confirm-btn" style="flex: 1; padding: 15px; height: auto; background: #fff; border: 1px solid #ddd;">
                        <canvas id="canvasLeft" width="200" height="200"></canvas>
                        <div style="font-weight: bold;">${okLabel}</div>
                    </button>

                    <button class="modal-btn cancel-btn" style="flex: 1; padding: 15px; height: auto; background: #fff; border: 1px solid #ddd;">
                        <canvas id="canvasRight" width="200" height="200"></canvas>
                        <div style="font-weight: bold;">${cancelLabel}</div>
                    </button>

                </div>
            </div>
        `;
        document.body.appendChild(overlay);

        const ctxL = document.getElementById('canvasLeft').getContext('2d');
        const ctxR = document.getElementById('canvasRight').getContext('2d');
        const centerX = 100;
        const centerY = 105; // Centrowanie pionowe dla lepszego balansu w przycisku

        const deg2Rad = (deg) => (deg * Math.PI) / 180;
        const getAngles = (deg) => {
            const span = deg2Rad(deg);
            return { start: -Math.PI / 2 - span / 2, end: -Math.PI / 2 + span / 2 };
        };

        function drawRadiusChange(ctx, oldR, newR, constA) {
            ctx.clearRect(0, 0, 200, 200);
            const angles = getAngles(constA);

            ctx.lineWidth = 1;
            ctx.strokeStyle = "#000000";
            ctx.beginPath();
            ctx.moveTo(centerX, centerY); ctx.lineTo(centerX + 80 * Math.cos(angles.start), centerY + 80 * Math.sin(angles.start));
            ctx.moveTo(centerX, centerY); ctx.lineTo(centerX + 80 * Math.cos(angles.end), centerY + 80 * Math.sin(angles.end));
            ctx.stroke();

            ctx.lineWidth = 2;
            ctx.setLineDash([5, 5]); ctx.strokeStyle = "#aaaaaa";
            ctx.beginPath(); ctx.arc(centerX, centerY, 80, angles.start, angles.end); ctx.stroke();
            
            ctx.setLineDash([]); ctx.strokeStyle = "#008ccf";
            ctx.beginPath(); ctx.arc(centerX, centerY, 55, angles.start, angles.end); ctx.stroke();

            ctx.strokeStyle = "#2ca02c";
            ctx.beginPath(); ctx.moveTo(centerX, centerY - 80); ctx.lineTo(centerX, centerY - 58); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(centerX - 8, centerY - 70); ctx.lineTo(centerX, centerY - 58); ctx.lineTo(centerX + 8, centerY - 70); ctx.stroke();

            //ctx.fillStyle = "#000000"; ctx.font = "bold 13px Arial"; ctx.textAlign = "center";
            //ctx.fillText(`${constA}°`, centerX, centerY + 45);

            ctx.fillStyle = "#2ca02c"; ctx.font = "bold 13px Arial"; ctx.textAlign = "center";
            ctx.fillText(`${oldR} mm ➔ ${newR} mm`, centerX, centerY - 90);
        }

        function drawAngleChange(ctx, constR, oldA, newA) {
            ctx.clearRect(0, 0, 200, 200);
            const anglesOld = getAngles(oldA);
            const anglesNew = getAngles(newA);

            ctx.lineWidth = 1; ctx.strokeStyle = "#000000";
            ctx.beginPath();
            ctx.moveTo(centerX, centerY); ctx.lineTo(centerX + 75 * Math.cos(anglesOld.start), centerY + 75 * Math.sin(anglesOld.start));
            ctx.moveTo(centerX, centerY); ctx.lineTo(centerX + 75 * -Math.cos(anglesOld.start), centerY + 75 * Math.sin(anglesOld.start));
            ctx.stroke();

            ctx.lineWidth = 1; ctx.strokeStyle = "#2ca02c";
            ctx.beginPath();
            ctx.moveTo(centerX, centerY); ctx.lineTo(centerX + 85 * Math.cos(anglesNew.start), centerY + 85 * Math.sin(anglesNew.start));
            ctx.moveTo(centerX, centerY); ctx.lineTo(centerX + 85 * -Math.cos(anglesNew.start), centerY + 85 * Math.sin(anglesNew.start));
            ctx.stroke();            

            ctx.lineWidth = 2;
            ctx.setLineDash([5, 5]); ctx.strokeStyle = "#aaaaaa";
            ctx.beginPath(); 
            ctx.arc(centerX, centerY, 75, anglesOld.start, anglesOld.end); ctx.stroke();
            
            ctx.setLineDash([]); ctx.strokeStyle = "#008ccf";
            ctx.beginPath(); ctx.arc(centerX, centerY, 75, anglesNew.start, anglesNew.end); ctx.stroke();

            ctx.strokeStyle = "#2ca02c";
            const arrowR = 90;
            ctx.beginPath(); ctx.arc(centerX, centerY, arrowR, anglesOld.end, anglesNew.end, true); ctx.stroke();

            ctx.save();
            ctx.translate(centerX + arrowR * Math.cos(anglesNew.end), centerY + arrowR * Math.sin(anglesNew.end));
            ctx.rotate(anglesNew.end); 
            ctx.beginPath(); ctx.moveTo(-10, 12); ctx.lineTo(0, 0); ctx.lineTo(10, 12); ctx.stroke();
            ctx.restore();

            //ctx.fillStyle = "#000000"; ctx.font = "bold 13px Arial"; ctx.textAlign = "center";
            //ctx.fillText(`R: ${constR} mm`, centerX, centerY + 45);

            ctx.fillStyle = "#2ca02c"; ctx.font = "bold 13px Arial"; ctx.textAlign = "center";
            ctx.fillText(`${oldA}° ➔ ${newA}°`, centerX, centerY - 90);
        }

        // Obsługa logiki wyboru trybu
        if (mode === "angle_mode") {
            drawRadiusChange(ctxL, vals.currentR, vals.newR, vals.currentA);
            drawAngleChange(ctxR, vals.currentR, vals.currentA, vals.newA);
        } else if (mode === "radius_mode") {
            drawAngleChange(ctxL, vals.currentR, vals.currentA, vals.newA);
            drawRadiusChange(ctxR, vals.currentR, vals.newR, vals.currentA);
        }

        overlay.querySelector(".confirm-btn").onclick = () => { overlay.remove(); callback(true); };
        overlay.querySelector(".cancel-btn").onclick = () => { overlay.remove(); callback(false); };
    }

    function getMaxRadiusForAngle(a) {
    if (a <= 0) return 20000;
    // Jeśli tryb zaawansowany jest włączony, limit 5750 przestaje istnieć
    const limit = (typeof isAdvancedMode !== 'undefined' && isAdvancedMode) ? 100000 : 5750;
    return Math.floor((360 * limit) / (2 * Math.PI * a));
}

    function checkFinalLimit(key, val) {
        if (key === 'angle') {
            setStandardAngle(angle_deg);
        }
    }

    function setStandardAngle(a) {
        const t = translations[currentLang];
        const limitR_system = getMaxRadiusForAngle(a);

        if (r > limitR_system + 0.1 && !window.isAdvancedMode) {
            const title = t.ask_title || "Limit";
            const safeAngleForCurrentR = Math.floor((5750 / r) * (180 / Math.PI)); // MAX_LEN to u Ciebie 5750

            // 1. Pobieramy grubość profilu
            const orientCombo = document.getElementById('orient_combo');
            const isHorizontal = orientCombo.selectedIndex === 0;
            const profile_t = isHorizontal ? profiles[selected_profile].w : profiles[selected_profile].h;

            // 2. Przeliczamy promienie na aktualny widok
            let currentViewR = r;
            let limitR_view = limitR_system;
            if (view_mode === "Krawędź wewnętrzna") {
                currentViewR = r - profile_t;
                limitR_view = limitR_system - profile_t;
            } else if (view_mode === "Środek profilu") {
                currentViewR = r - profile_t / 2;
                limitR_view = limitR_system - profile_t / 2;
            }

            // 3. Budujemy komunikaty
            let msg = t.ask_limit
                .replace(/{newAngle}/g, safeAngleForCurrentR)
                .replace(/{newRadius}/g, Math.round(limitR_view))
                .replace(/{radius}/g, Math.round(currentViewR))
                .replace(/{angle}/g, Math.round(a));

            let btnOk = t.btn_confirm.replace(/{angle}/g, Math.round(a)).replace(/{newRadius}/g, Math.round(limitR_view));
            let btnNo = t.btn_cancel.replace(/{radius}/g, Math.round(currentViewR)).replace(/{newAngle}/g, safeAngleForCurrentR);
            
            // --- POPRAWIONY VALS (Używa istniejących zmiennych) ---
            const vals = {
                currentR: Math.round(currentViewR), 
                newR: Math.round(limitR_view),
                currentA: Math.round(a),
                newA: safeAngleForCurrentR
            };

            customConfirm(msg, title, (userAgrees) => {
                if (userAgrees) {
                    r = limitR_system;
                    angle_deg = a;
                } else {
                    angle_deg = safeAngleForCurrentR;
                }
                updateLimits();
                updateUIElements();
            }, btnOk, btnNo, "angle_mode", vals);
        } else {
            angle_deg = a;
            updateLimits();
            updateUIElements();
        }
    }

	// RYSUNEK //
    async function drawPlot(data, t_mm, isExport = false) {
        const canvas = document.getElementById('plot-canvas');
        const orientCombo = document.getElementById('orient_combo');
        let horizontal = (orientCombo.selectedIndex === 0);
        const ctx = canvas.getContext('2d');
        const t_plot = translations[currentLang];
        const winW = window.innerWidth;
        let Scale = 1.0
        let lineScale = 1.0
        if (!isExport && winW < 1000) {
            Scale = 1.0 + ((1000 - winW) / 300);
            lineScale = Scale * 0.4
        }
        const fontSize = Math.min(Math.max(Math.round(16 * Scale), 20), 32);
        const isPortrait = !isExport && window.innerHeight > window.innerWidth;
        const isMobile = !isExport && window.innerWidth < 1000;
        
        // 1. Konfiguracja Canvasu
        const rect = canvas.parentElement.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        const r_disp = data.radius;
        const rad = angle_deg * Math.PI / 180;
        const startAng = Math.PI/2 - rad/2;
        const endAng = Math.PI/2 + rad/2;
        const rad_half = rad / 2;

        // 2. Promień zewnętrzny dla gabarytów
        let r_ext_calc = r; 
        if (view_mode === "Krawędź wewnętrzna") r_ext_calc = data.radius + t_mm;
        if (view_mode === "Środek profilu") r_ext_calc = data.radius + t_mm/2;

        // 3. LOGIKA GABARYTU WYSOKOŚCI(SPRAWDZONA DLA KAŻDEGO KĄTA)
        const y_top_phys = r_ext_calc; 
        const y_ext_corner = r_ext_calc * Math.cos(rad_half);
        const y_int_corner = (r_ext_calc - t_mm) * Math.cos(rad_half);
        const y_bottom_phys = Math.min(y_ext_corner, y_int_corner);
        const g_h_phys = y_top_phys - y_bottom_phys;

        // 4. SZEROKOŚĆ GABARYTOWA (TWOJA LOGIKA)
        const g_w = (angle_deg > 180) ? 2 * r_ext_calc : 2 * r_ext_calc * Math.sin(rad_half);

        // 5. SKALOWANIE I KADROWANIE
        const margin_side = isPortrait ? 150 : 500;
        const view_min_x = (r_ext_calc * Math.cos(endAng)) - margin_side;
        const view_max_x = (r_ext_calc * Math.cos(startAng)) + margin_side;
        const world_w = view_max_x - view_min_x;
        const view_max_y = r_ext_calc + 500;
        const bottom_padding = 800 * Scale
        const view_min_y = Math.min(y_bottom_phys - bottom_padding, view_max_y - (world_w * 0.6));
        const scale = Math.min(canvas.width / world_w, canvas.height / (view_max_y - view_min_y));
        const offsetX = (canvas.width / 2) - ((view_max_x + view_min_x) / 2 * scale);
        const centerY_geo = y_bottom_phys + (g_h_phys / 2);
        const offsetY = (canvas.height / 2.5) + (centerY_geo * scale);

        // 6. RYSOWANIE GEOMETRII
        ctx.save();
        ctx.translate(offsetX, offsetY);
        ctx.scale(scale, -scale);
        
        // Profil (szary)
        ctx.beginPath();
        ctx.arc(0, 0, r_ext_calc, startAng, endAng);
        ctx.arc(0, 0, r_ext_calc - t_mm, endAng, startAng, true);
        ctx.fillStyle = "#e0e0e0"; ctx.fill();
        ctx.strokeStyle = "#555"; ctx.lineWidth = 1/scale * lineScale; ctx.stroke();

        //Światło
        let rStart, rEnd;
        if (orientCombo.selectedIndex === 2) {
            // Światło na zewnątrz
            rStart = r_ext_calc;
            rEnd = r_ext_calc + 75;
        } else if (orientCombo.selectedIndex === 1) {
            // Światło do wewnątrz
            rStart = r_ext_calc - t_mm;
            rEnd = r_ext_calc - t_mm - 75;
        } else {
            // Światło obustronne (50px w każdą stronę od krawędzi profilu)
            rStart = r_ext_calc;
            rEnd = r_ext_calc - t_mm;
        }

        // Wspólny kod rysujący
        ctx.beginPath();
        let grad = ctx.createRadialGradient(0, 0, rStart, 0, 0, rEnd);
        grad.addColorStop(0, "rgba(229, 231, 117, 0.6)");
        grad.addColorStop(1, "rgba(207, 211, 0, 0)");
        ctx.arc(0, 0, rEnd, startAng, endAng);
        ctx.arc(0, 0, rStart, endAng, startAng, true);
        ctx.fillStyle = grad; 
        ctx.fill();

        // Promienie pomocnicze
        ctx.strokeStyle = "#2ca02c"; ctx.lineWidth = 2/scale * lineScale; ctx.setLineDash([20, 10]);
        ctx.beginPath();
        ctx.moveTo(0,0); ctx.lineTo(r_disp * Math.cos(startAng), r_disp * Math.sin(startAng));
        ctx.moveTo(0,0); ctx.lineTo(r_disp * Math.cos(endAng), r_disp * Math.sin(endAng)); 
        ctx.stroke();

        // Cięciwa i h (niebieskie)
        ctx.strokeStyle = "#007acc"; ctx.lineWidth = 1/scale * lineScale; ctx.setLineDash([20, 20]);
        ctx.beginPath(); 
        ctx.moveTo(r_disp*Math.cos(startAng), r_disp*Math.sin(startAng)); 
        ctx.lineTo(r_disp*Math.cos(endAng), r_disp*Math.sin(endAng)); 
        ctx.stroke();
        ctx.beginPath(); 
        ctx.moveTo(0, r_disp*Math.sin(startAng)); ctx.lineTo(0, r_disp); 
        ctx.stroke();

        // Główna linia gięcia
        ctx.setLineDash([]);
        ctx.strokeStyle = (r_disp * rad >= 5749) ? "#e31a1c" : "#2ca02c"; ctx.lineWidth = 2/scale * lineScale;
        ctx.beginPath(); ctx.arc(0, 0, r_disp, startAng, endAng); ctx.stroke();
        ctx.restore();

        // 7. TEKSTY
        const drawT = (t, x, y, c, b=false, align="center", rot=0) => {
            const sx = (x * scale) + offsetX;
            const sy = offsetY - (y * scale);
            ctx.save(); ctx.translate(sx, sy); ctx.rotate(rot);
            ctx.fillStyle = c; 
            ctx.font = `${b?'bold':''} ${fontSize}px Figtree`; 
            ctx.textAlign = align;
            ctx.fillText(t, 0, 0); ctx.restore();
        };

        const labelS = isMobile ? "s" : `s = ${Math.round(data.arc_len)} mm`;
        const labelR = isMobile ? "r" : `r = ${Math.round(r_disp)} mm`;
        const labelH = isMobile ? "h" : `h = ${Math.round(data.height)} mm`;
        const labelC = isMobile ? "c" : `c = ${Math.round(data.chord)} mm`;

        drawT(labelS, 0, r_disp + 90, "#2ca02c", true);
        let rFactor = (angle_deg <= 90) ? (0.99 - (angle_deg/360)) : 0.8;
        drawT(labelR, (r_disp * rFactor) * Math.cos(startAng), (r_disp * rFactor) * Math.sin(startAng) + 25, "#2ca02c", true, "center", -startAng);
        drawT(labelH, 30, (r_disp * Math.sin(startAng) + r_disp) * 0.5, "#007acc", true, "left");
        drawT(labelC, 0, r_disp * Math.sin(startAng) - 60 * Scale, "#007acc", true);

        // 8. MIARKI GABARYTOWE
        const sL = ((-g_w/2) * scale) + offsetX;
        const sR = ((g_w/2) * scale) + offsetX;
        const sT = offsetY - (y_top_phys * scale);
        const sB = offsetY - (y_bottom_phys * scale);
        const sEdgeB = canvas.height - (80 * Scale);

        // LEGENDA DLA TRYBU MOBILE

        // Wysokość gabarytowa (Lewa)
        if (!isMobile) {
        ctx.strokeStyle = "rgba(150, 150, 150, 0.4)"; ctx.setLineDash([5, 5]);
        ctx.beginPath(); ctx.moveTo(sL, sT); ctx.lineTo(60 * Scale, sT); ctx.moveTo(sL, sB); ctx.lineTo(60 * Scale, sB); ctx.stroke();
        ctx.setLineDash([]); ctx.strokeStyle = "#888";
        ctx.beginPath(); ctx.moveTo(60 * Scale, sT); ctx.lineTo(60 * Scale, sB); ctx.stroke();
        ctx.save(); ctx.translate(25 * Scale, (sT + sB) / 2); ctx.rotate(-Math.PI / 2);
        ctx.fillStyle = "#333"; ctx.font = `bold ${fontSize}px Figtree`; ctx.textAlign = "center";
        ctx.fillText(`${t_plot.total_height}: ${Math.round(g_h_phys)} mm`, 0, 0); ctx.restore();

        // Szerokość gabarytowa (Dół)
        ctx.strokeStyle = "rgba(150, 150, 150, 0.4)"; ctx.setLineDash([5, 5]);
        ctx.beginPath(); ctx.moveTo(sL, sB); ctx.lineTo(sL, sEdgeB - 40 * Scale); ctx.moveTo(sR, sB); ctx.lineTo(sR, sEdgeB - 40 * Scale); ctx.stroke();
        ctx.setLineDash([]); ctx.strokeStyle = "#888";
        ctx.beginPath(); ctx.moveTo(sL, sEdgeB - 25 * Scale); ctx.lineTo(sR, sEdgeB - 25 * Scale); ctx.stroke();
        ctx.fillStyle = "#333"; ctx.font = `bold ${fontSize}px Figtree`; ctx.textAlign = "center";
        ctx.fillText(`${t_plot.total_width}: ${Math.round(g_w)} mm`, (sL + sR) / 2, sEdgeB);

        // Oznaczenie trybu pomiaru i tolerancja
        const modeKeys = {
            "Krawędź wewnętrzna": "view_inner",
            "Środek profilu": "view_center",
            "Krawędź zewnętrzna": "view_outer"
        };
        const translatedViewMode = t_plot[modeKeys[view_mode]] || view_mode.toUpperCase();

        ctx.fillStyle = "#007acc"; ctx.font = `bold ${fontSize}px Figtree`; ctx.textAlign = "center";
        ctx.fillText(`${t_plot.measure_to}: ${translatedViewMode}`, (sL + sR) / 2, sEdgeB + 35 * Scale);
        ctx.fillText(t_plot.tolerance_msg, (sL + sR) / 2, sEdgeB + 65 * Scale);
        }

        if (isMobile) {
        ctx.textAlign = isPortrait ? "center" : "left";
        ctx.font = `bold ${fontSize * 0.7}px Figtree`;
        ctx.fillStyle = "#333";

        const legendLines = [
            `s: ${Math.round(data.arc_len)} mm`,
            `r: ${Math.round(data.radius)} mm`,
            `h: ${Math.round(data.height)} mm`,
            `c: ${Math.round(data.chord)} mm`,
            `α: ${Math.round(angle_deg)}°`,
            `${t_plot.total_height}: ${Math.round(g_h_phys)} mm`,
            `${t_plot.total_width}: ${Math.round(g_w)} mm`
        ];

        if (isPortrait) {
            // Pod rysunkiem
            let legY = canvas.height - (canvas.height / 4);
            legendLines.forEach((line, i) => {
                ctx.fillText(line, canvas.width / 2, legY + (i * fontSize));
            });
        } else {
            // Po prawej stronie (Landscape)
            let legY = window.innerHeight * 0.10;
            let legX = window.innerWidth / 20;
            legendLines.forEach((line, i) => {
                ctx.fillText(line, legX, legY + (i * fontSize));
            });
        }
    }

        // 9. KĄT WEWNĄTRZ
        let distFactor = (angle_deg <= 90) ? (1 - (angle_deg/360) - (angle_deg / 90) * 0.4) : 0.2;
        const dArcDist = r_disp * distFactor;
        const labelAlfa = isMobile ? `α` : `${Math.round(angle_deg)}°`;
        ctx.save(); ctx.translate(offsetX, offsetY); ctx.scale(scale, -scale);
        ctx.beginPath(); ctx.arc(0, 0, dArcDist, startAng, endAng);
        ctx.strokeStyle = "#2ca02c"; ctx.setLineDash([]); ctx.lineWidth = 2 / scale * lineScale; ctx.stroke();
        ctx.restore();
        drawT(labelAlfa, -120, dArcDist , "#2ca02c", true);

        // --- RYSOWANIE PODZIAŁU NA SEGMENTY ---
        if (typeof isAdvancedMode !== 'undefined' && isAdvancedMode) {
            const slider = document.getElementById('segment_slider');
            if (slider) {
                const count = parseInt(slider.value);
                const rad_total = angle_deg * Math.PI / 180;
                // Kąt startowy łuku w Twoim systemie to zazwyczaj góra (-90st) minus połowa rozwarcia
                const start_a = -Math.PI / 2 - rad_total / 2;

                ctx.save();
                ctx.strokeStyle = "#ff4444";
                ctx.lineWidth = 3; 

                for (let i = 1; i < count; i++) {
                    const current_a = start_a + (i * (rad_total / count));
                    // Rysujemy kreskę przecinającą profil (r +/- 150mm)
                    const x1 = (r - 150) * Math.cos(current_a);
                    const y1 = (r - 150) * Math.sin(current_a);
                    const x2 = (r + 150) * Math.cos(current_a);
                    const y2 = (r + 150) * Math.sin(current_a);

                    ctx.beginPath();
                    ctx.moveTo(x1, y1);
                    ctx.lineTo(x2, y2);
                    ctx.stroke();
                }
                ctx.restore();
            }
        }
    }

    function updateMaterialBar() {
        const canvas = document.getElementById('raw-canvas');
        const ctx = canvas.getContext('2d');
        const waste = 200;
