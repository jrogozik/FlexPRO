    function setGeometryFromValue(key, val) {
        const orientCombo = document.getElementById('orient_combo');
        const isHorizontal = orientCombo.selectedIndex === 0; 
        const t = isHorizontal ? profiles[selected_profile].w : profiles[selected_profile].h;
        const getBaseR = () => r - (view_mode === "Krawędź wewnętrzna" ? t : (view_mode === "Środek profilu" ? t/2 : 0));

        if (key === "radius") {
            if (view_mode === "Krawędź wewnętrzna") r = val + t;
            else if (view_mode === "Środek profilu") r = val + t/2;
            else r = val;
        } 
        else if (key === "diameter") {
            let rv = val / 2;
            if (view_mode === "Krawędź wewnętrzna") r = rv + t;
            else if (view_mode === "Środek profilu") r = rv + t/2;
            else r = rv;
        }
        else if (key === "angle") {
            angle_deg = val;
        }
        else if (key === "arc_len") {
            let ra = getBaseR();
            angle_deg = (val / ra) * (180 / Math.PI);
        }
        else if (key === "chord") {
            let ra = getBaseR();
            let sinHalf = val / (2 * ra);
            if (sinHalf <= 1) {
                angle_deg = 2 * Math.asin(sinHalf) * (180 / Math.PI);
            }
        }
        else if (key === "height") {
            let ra = getBaseR();
            let cosHalf = 1 - (val / ra);
            if (cosHalf >= -1 && cosHalf <= 1) {
                angle_deg = 2 * Math.acos(cosHalf) * (180 / Math.PI);
            }
        }
    }

