function getFileNameFromUser(defaultName) {
    return new Promise((resolve) => {
        const modal = document.getElementById('export-modal');
        const input = document.getElementById('export-filename-input');
        const confirmBtn = document.getElementById('confirm-export-btn');

        if (!modal || !input || !confirmBtn) {
            console.error("BŁĄD: Nie znaleziono elementów modala w HTML!", { modal, input, confirmBtn });
            resolve(defaultName); // Wyjdź z obietnicy, żeby nie zawiesić aplikacji
            return;
        }

        // Tłumaczenie tytułów w locie (opcjonalnie)
        const t = translations[currentLang];
        document.getElementById('export-title').innerText = t.export_title || "Save project";
        document.getElementById('export-text').innerText = t.export_prompt || "Change file name:";
        document.getElementById('confirm-export-btn').innerText = t.export_ok || "Save";
        document.getElementById('cancel-export-btn').innerText = t.export_cancel || "Cancel";

        input.value = defaultName;
        modal.style.display = 'flex';

        confirmBtn.onclick = () => {
            modal.style.display = 'none';
            resolve(input.value.trim() || defaultName);
        };

        // Obsługa klawisza Enter
        input.onkeydown = (e) => {
            if (e.key === 'Enter') confirmBtn.click();
            if (e.key === 'Escape') closeExportModal();
        };
    });
}

function closeExportModal() {
    const modal = document.getElementById('export-modal');
    modal.style.display = 'none';
}

